# Neon Postgres connection string — get it from https://console.neon.tech
# (Project → Connection Details → copy the pooled connection string)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js session encryption secret — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"

# First admin user, created by `npm run db:seed`
SEED_ADMIN_NAME="Aaron Arvizu"
SEED_ADMIN_EMAIL="aaron.h.arvizu@gmail.com"
SEED_ADMIN_PASSWORD="change-me-now"
